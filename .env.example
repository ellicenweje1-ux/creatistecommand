# ── The Creatiste Command — backend configuration ─────────────────────────────
# Copy to .env and `export $(grep -v '^#' .env | xargs)` before launching,
# or set these in your hosting provider's environment settings.

# Security — set a long random string in production (auto-generated for dev if unset)
SECRET_KEY=

# Public URL of the deployed app (used in Stripe redirect URLs)
APP_URL=http://localhost:8000

# ── Platform admin (created automatically on first startup) ──────────────────
ADMIN_EMAIL=admin@creatistecommand.com
ADMIN_PASSWORD=admin12345          # ⚠ change this before going live
ADMIN_NAME=Platform Admin

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
# Leave blank to run in DEMO BILLING mode (chef activation is simulated).
# With keys set, onboarding fee + monthly subscription are charged via
# Stripe Checkout, and the webhook keeps subscription statuses in sync.
#   Webhook endpoint:  POST {APP_URL}/api/billing/webhook
#   Events to send:    checkout.session.completed, invoice.payment_failed,
#                      customer.subscription.deleted
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AI sous-chef (Claude / Anthropic) ─────────────────────────────────────────
# Leave blank to disable AI features gracefully (everything else still works).
# EMERGENT_LLM_KEY is accepted as an alias for the same value.
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# ── Storage ───────────────────────────────────────────────────────────────────
# DATABASE_URL=sqlite:///backend/data/creatiste.db   (default; any SQLAlchemy URL works)
# UPLOAD_DIR=backend/data/uploads
# MAX_UPLOAD_MB=10
# DEFAULT_CURRENCY=GBP
